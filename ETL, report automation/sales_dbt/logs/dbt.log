    create  table
      "retail_analytics"."analytics"."fct_customer_metrics__dbt_tmp"
  
    as (
      

WITH customer_stats AS (
    SELECT
        customer_id,
        country,
        COUNT(DISTINCT order_id) AS frequency,
        SUM(order_revenue) AS monetary,
        MAX(order_date) AS last_order_date,
        MIN(order_date) AS first_order_date,
        DATE_DIFF('day', MIN(order_date), MAX(order_date)) AS customer_lifetime_days
    FROM "retail_analytics"."analytics"."stg_orders"
    WHERE customer_id IS NOT NULL
    GROUP BY 1, 2
)

SELECT
    *,
    -- Recency: дней с последнего заказа (на дату последнего заказа в датасете)
    DATE_DIFF('day', last_order_date, (SELECT MAX(order_date) FROM "retail_analytics"."analytics"."stg_orders")) AS recency_days,
    -- Простая сегментация
    CASE 
        WHEN frequency >= 10 AND monetary >= 500 THEN 'Champions'
        WHEN frequency >= 5 AND monetary >= 200 THEN 'Loyal'
        WHEN recency_days <= 30 THEN 'Recent'
        WHEN recency_days > 180 THEN 'At Risk'
        ELSE 'Regular'
    END AS rfm_segment
FROM customer_stats
    );
  
  
